{
  "name": "devsecops-ci-pipeline",
  "version": "1.0.0",
  "description": "A minimal Node.js API demonstrating a DevSecOps CI pipeline with enforced security gates.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "lint": "eslint src/ tests/"
  },
  "dependencies": {
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0"
  },
  "devDependencies": {
    "eslint": "^9.39.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageReporters": [
      "lcov",
      "text",
      "html"
    ],
    "coverageDirectory": "coverage"
  },
  "engines": {
    "node": ">=20"
  }
}
